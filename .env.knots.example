# War Room — Bitcoin Knots node credentials
# Copy this file to .env.knots and fill in your values
# .env.knots is gitignored and never committed

# ----- Bitcoin Core node (your existing pool node) -----
# These should match your existing .env / .env.secrets
BITCOIN_RPC_HOST=
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASS=
BITCOIN_ZMQ_HASHBLOCK=

# ----- Bitcoin Knots node -----
KNOTS_RPC_HOST=
KNOTS_RPC_PORT=8332
KNOTS_RPC_USER=
KNOTS_RPC_PASS=
KNOTS_ZMQ_HASHBLOCK=

# ----- Shared pool settings -----
STRATUM_PORT=3333
MIN_DIFFICULTY=1
START_DIFFICULTY=10000
MAX_DIFFICULTY=0

# ----- WebUI -----
MEMPOOL_API_URL=https://mempool.space/api
TZ=UTC
