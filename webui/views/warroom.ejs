</style>

<script>
(function() {
    function fmtHash(hs) {
        if (!hs || hs <= 0) return '0 H/s';
        if (hs >= 1e18) return (hs / 1e18).toFixed(2) + ' EH/s';
        if (hs >= 1e15) return (hs / 1e15).toFixed(2) + ' PH/s';
        if (hs >= 1e12) return (hs / 1e12).toFixed(2) + ' TH/s';
        if (hs >= 1e9)  return (hs / 1e9).toFixed(2) + ' GH/s';
        if (hs >= 1e6)  return (hs / 1e6).toFixed(2) + ' MH/s';
        return (hs / 1e3).toFixed(2) + ' KH/s';
    }

    function fmtDiff(d) {
        if (!d || d <= 0) return '—';
        if (d >= 1e12) return (d / 1e12).toFixed(2) + ' T';
        if (d >= 1e9)  return (d / 1e9).toFixed(2) + ' G';
        if (d >= 1e6)  return (d / 1e6).toFixed(2) + ' M';
        if (d >= 1e3)  return (d / 1e3).toFixed(2) + ' K';
        return d.toFixed(0);
    }

    function setText(id, val) {
        const el = document.getElementById(id);
        if (el) el.textContent = val;
    }

    function updateSide(prefix, side) {
        const statusEl = document.querySelector(`#${prefix}-status`);
        const dotEl    = statusEl?.querySelector('.wr-status-dot');

        if (!side.online) {
            if (dotEl)    dotEl.className = 'wr-status-dot offline';
            if (statusEl) statusEl.lastChild.textContent = ' Offline';
            setText(`${prefix}-hashrate`, '—');
            setText(`${prefix}-miners`,   '—');
            setText(`${prefix}-blocks`,   '—');
            setText(`${prefix}-bestdiff`, '—');
            return;
        }

        if (dotEl)    dotEl.className = 'wr-status-dot online';
        if (statusEl) statusEl.lastChild.textContent = ' Online';

        setText(`${prefix}-hashrate`, fmtHash(side.hashrate1m || side.hashrate));
        setText(`${prefix}-miners`,   side.workers || 0);
        setText(`${prefix}-blocks`,   side.blocksFound || 0);
        setText(`${prefix}-bestdiff`, fmtDiff(side.bestDiff));
    }

    async function loadWarroom() {
        try {
            const res  = await window.secureFetch('/api/warroom');
            const json = await res.json();

            if (!json.success) {
                document.getElementById('wr-error').style.display = '';
                setText('wr-error-msg', json.error || 'War Room unavailable');
                return;
            }

            const { core, knots, corePct, knotsPct } = json.data;

            // Tug-of-war bar
            const cp = corePct.toFixed(1);
            const kp = knotsPct.toFixed(1);
            const towCore  = document.getElementById('tow-core');
            const towKnots = document.getElementById('tow-knots');
            if (towCore)  towCore.style.width  = cp + '%';
            if (towKnots) towKnots.style.width = kp + '%';
            setText('tow-pct-core',   cp + '%');
            setText('tow-pct-knots',  kp + '%');
            setText('tow-label-core',  fmtHash(core.hashrate1m));
            setText('tow-label-knots', fmtHash(knots.hashrate1m));

            updateSide('core',  core);
            updateSide('knots', knots);

            // Live badge
            const badge = document.getElementById('wr-live-badge');
            if (badge) badge.classList.add('live');
            setText('wr-live-text', 'Live · ' + new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}));

        } catch (err) {
            console.error('War Room fetch failed:', err);
            setText('wr-live-text', 'Error');
        }
    }

    // Stratum URLs from hostname
    document.addEventListener('DOMContentLoaded', function() {
        const host = location.hostname;
        setText('core-stratum',  `stratum+tcp://${host}:3333`);
        setText('knots-stratum', `stratum+tcp://${host}:3334`);

        loadWarroom();
        setInterval(loadWarroom, 5000);
    });
})();
</script>
